# stream server
STREAM_SERVER_DEBUG_MODE=true
SYMBOLS=XLMUSDT

# mongo
MONGO_DEBUG_MODE=true
MONGO_URI=mongodb://mongodb:27017
MONGO_DATABASE_NAME=data_store

# mongo-express
MONGO_INITDB_ROOT_USERNAME=username
MONGO_INITDB_ROOT_PASSWORD=password
ME_CONFIG_MONGODB_SERVER=mongodb
ME_CONFIG_MONGODB_URL=mongodb:27017
ME_CONFIG_MONGODB_ADMINUSERNAME=username
ME_CONFIG_MONGODB_ADMINPASSWORD=password

# jetstream
JETSTREAM_DEBUG_MODE=TRUE
NATS_URL=nats://jetstream:4222
JETSTREAM_STREAM_NAME=EVENTS
JETSTREAM_SUBJECT=input.events
JETSTREAM_DURABLE=connector-durable

JS_RETENTION=limits
JS_REPLICAS=1
JS_STORAGE=file

# Data Connector
CONNECTOR_INPUT_STREAM=EVENTS
CONNECTOR_INPUT_SUBJECT=input.events
CONNECTOR_DURABLE_CONSUMER=data-connector
CONNECTOR_OUTPUT_SUBSCRIBERS=consumer.mongo,consumer.telegram.bot,consumer.stream.analytics